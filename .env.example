# Copie ce fichier en ".env" et remplis les valeurs

# Token du bot (depuis le Discord Developer Portal)
DISCORD_TOKEN=ton_token_ici

# ID du rôle à attribuer lors de la vérification
# Clic droit sur le rôle > Copier l'identifiant
VERIFIED_ROLE_ID=123456789012345678

# ID du salon où envoyer la commande /setup-verification
# Clic droit sur le salon > Copier l'identifiant
VERIFICATION_CHANNEL_ID=123456789012345678
